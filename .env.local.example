# ─────────────────────────────────────────────────────────────────────────────
# Supabase — required for auth + database
# Find these values in your Supabase project at:
#   https://app.supabase.com → Project Settings → API
# ─────────────────────────────────────────────────────────────────────────────

# Project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here

# Anon / public key (safe to expose to the browser; access is governed by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service-role key — NEVER expose this to the browser.
# Required for privileged server-side operations that bypass RLS.
# Found under: Project Settings → API → service_role secret
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
